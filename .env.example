# Backend model configuration: DeepSeek OpenAI-compatible API
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2

# Reasoning engine: llm uses OPENAI_BASE_URL / OPENAI_MODEL.
REASONING_ENGINE=llm

# SGLang OpenAI-compatible endpoint
SGLANG_BASE_URL=
SGLANG_MODEL=default

# Frontend -> backend API base URL
NEXT_PUBLIC_API_BASE=http://localhost:8000
